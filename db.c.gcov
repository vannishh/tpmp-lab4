        -:   37:/* ------------------------------------------------------------------ */
       30:   38:int db_init(sqlite3 *db)
        -:   39:{
       30:   40:    const char *schema =
        -:   41:        "PRAGMA foreign_keys = ON;"
        -:   42:
        -:   43:        "CREATE TABLE IF NOT EXISTS FLEET_USERS ("
        -:   44:        "  user_id   INTEGER PRIMARY KEY AUTOINCREMENT,"
        -:   45:        "  username  TEXT    NOT NULL UNIQUE,"
        -:   46:        "  password  TEXT    NOT NULL,"
        -:   47:        "  role      TEXT    NOT NULL CHECK(role IN ('admin','driver')),"
        -:   48:        "  driver_id INTEGER DEFAULT 0,"
        -:   49:        "  FOREIGN KEY (driver_id) REFERENCES FLEET_DRIVERS(driver_id)"
        -:   50:        ");"
        -:   51:
        -:   52:        "CREATE TABLE IF NOT EXISTS FLEET_CARS ("
        -:   53:        "  car_id          INTEGER PRIMARY KEY AUTOINCREMENT,"
        -:   54:        "  license_plate   TEXT    NOT NULL UNIQUE,"
        -:   55:        "  brand           TEXT    NOT NULL,"
        -:   56:        "  initial_mileage INTEGER NOT NULL DEFAULT 0,"
        -:   57:        "  capacity        REAL    NOT NULL"
        -:   58:        ");"
        -:   59:
        -:   60:        "CREATE TABLE IF NOT EXISTS FLEET_DRIVERS ("
        -:   61:        "  driver_id   INTEGER PRIMARY KEY AUTOINCREMENT,"
        -:   62:        "  employee_id TEXT    NOT NULL UNIQUE,"
        -:   63:        "  last_name   TEXT    NOT NULL,"
        -:   64:        "  category    TEXT    NOT NULL,"
        -:   65:        "  experience  INTEGER NOT NULL,"
        -:   66:        "  address     TEXT,"
        -:   67:        "  birth_year  INTEGER NOT NULL"
        -:   68:        ");"
        -:   69:
        -:   70:        "CREATE TABLE IF NOT EXISTS FLEET_ORDERS ("
        -:   71:        "  order_id       INTEGER PRIMARY KEY AUTOINCREMENT,"
        -:   72:        "  order_date     DATE    NOT NULL,"
        -:   73:        "  driver_id      INTEGER NOT NULL,"
        -:   74:        "  car_id         INTEGER NOT NULL,"
        -:   75:        "  distance_km    REAL    NOT NULL,"
        -:   76:        "  cargo_weight   REAL    NOT NULL,"
        -:   77:        "  transport_cost REAL    NOT NULL,"
        -:   78:        "  FOREIGN KEY (driver_id) REFERENCES FLEET_DRIVERS(driver_id),"
        -:   79:        "  FOREIGN KEY (car_id)    REFERENCES FLEET_CARS(car_id)"
        -:   80:        ");"
        -:   81:
        -:   82:        /* Earnings summary table (populated by fn_calculate_earnings) */
        -:   83:        "CREATE TABLE IF NOT EXISTS FLEET_EARNINGS ("
        -:   84:        "  earnings_id   INTEGER PRIMARY KEY AUTOINCREMENT,"
        -:   85:        "  driver_id     INTEGER NOT NULL,"
        -:   86:        "  period_start  DATE    NOT NULL,"
        -:   87:        "  period_end    DATE    NOT NULL,"
        -:   88:        "  total_earnings REAL   NOT NULL,"
        -:   89:        "  FOREIGN KEY (driver_id) REFERENCES FLEET_DRIVERS(driver_id)"
        -:   90:        ");"
        -:   91:
        -:   92:        /* Trigger: prevent order if cargo > car capacity */
        -:   93:        "CREATE TRIGGER IF NOT EXISTS trg_check_cargo "
        -:   94:        "BEFORE INSERT ON FLEET_ORDERS "
        -:   95:        "BEGIN "
        -:   96:        "  SELECT CASE "
        -:   97:        "    WHEN NEW.cargo_weight > (SELECT capacity FROM FLEET_CARS "
        -:   98:        "                             WHERE car_id = NEW.car_id) "
        -:   99:        "    THEN RAISE(ABORT,'Cargo weight exceeds vehicle capacity') "
        -:  100:        "  END; "
        -:  101:        "END;"
        -:  102:
        -:  103:        /* Seed admin user (password = 'admin123') */
        -:  104:        "INSERT OR IGNORE INTO FLEET_USERS(username,password,role)"
        -:  105:        "  VALUES('admin','admin123','admin');";
        -:  106:
       30:  107:    return db_execute(db, schema);
        -:  108:}
